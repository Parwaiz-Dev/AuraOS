              ]
            },
            "description": "Get all tables in the restaurant"
          },
          "response": []
        },
        {
          "name": "Get Tables with Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tables/with-status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tables",
                "with-status"
              ]
            },
            "description": "Get all tables with real-time status (occupied, vacant, reserved)"
          },
          "response": []
        },
        {
          "name": "Get Table Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tables/{{table_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tables",
                "{{table_id}}"
              ]
            },
            "description": "Get details of a specific table including recent orders"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Menu",
      "item": [
        {
          "name": "Get Complete Menu",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/menus",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "menus"
              ]
            },
            "description": "Get complete menu with all categories, items, and modifiers"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  if (response.data.categories && response.data.categories.length > 0) {",
                  "    const firstItem = response.data.categories[0].items[0];",
                  "    pm.environment.set('menu_item_id', firstItem.id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Menu Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/menus/categories",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "menus",
                "categories"
              ]
            },
            "description": "Get all menu categories"
          },
          "response": []
        },
        {
          "name": "Get Menu Items in Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/menus/categories/{{category_id}}/items",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "menus",
                "categories",
                "{{category_id}}",
                "items"
              ]
            },
            "description": "Get all items in a specific category"
          },
          "response": []
        },
        {
          "name": "Get Specific Menu Item",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/menus/items/{{menu_item_id}}",
              "host": [
