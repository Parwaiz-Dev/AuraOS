  "clientExamples": [
    {
      "description": "React Native Example - Listen to Order Ready Event",
      "code": "import io from 'socket.io-client';\n\nconst socket = io('http://localhost:3000', {\n  auth: {\n    token: accessToken\n  }\n});\n\nsocket.on('connect', () => {\n  console.log('Connected to server');\n  socket.emit('join_restaurant', {\n    restaurant_id: restaurantId\n  });\n});\n\nsocket.on('ORDER_READY', (payload) => {\n  console.log('Order ready for pickup:', payload);\n  playSound('order-ready.mp3');\n  dispatch(showNotification({\n    title: `Order ${payload.order_number} Ready!`,\n    body: `Table ${payload.table_number}`,\n    priority: 'high'\n  }));\n});\n\nsocket.on('disconnect', () => {\n  console.log('Disconnected from server');\n});"
    },
    {
      "description": "Handle Order Status Updates",
      "code": "socket.on('ORDER_UPDATED', (payload) => {\n  const { order_number, new_status } = payload;\n  \n  // Update Redux store\n  dispatch(updateOrderStatus({\n    orderNumber: order_number,\n    status: new_status\n  }));\n  \n  // Show toast notification\n  if (new_status === 'PREPARING') {\n    showToast(`Order ${order_number} is being prepared`);\n  }\n});"
    },
    {
      "description": "Reconnection with Exponential Backoff",
      "code": "const socket = io('http://localhost:3000', {\n  auth: { token: accessToken },\n  reconnection: true,\n  reconnectionDelay: 1000,\n  reconnectionDelayMax: 5000,\n  reconnectionAttempts: 5\n});\n\nsocket.on('reconnect', () => {\n  console.log('Reconnected after disconnect');\n  \n  // Re-join restaurant room\n  socket.emit('join_restaurant', {\n    restaurant_id: restaurantId\n  });\n  \n  // Sync any pending actions\n  syncPendingOrders();\n});"
    }
  ]
