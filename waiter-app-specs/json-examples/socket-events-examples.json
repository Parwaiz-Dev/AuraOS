  "connectionEvents": [
    {
      "name": "Connection Handshake",
      "step": "1. Client connects with JWT",
      "event": {
        "type": "connection",
        "handshakeData": {
          "auth": {
            "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        }
      },
      "serverResponse": "✅ Authentication successful, user can receive events"
    },
    {
      "name": "Join Restaurant Room",
      "step": "2. Client requests to join restaurant",
      "event": {
        "type": "emit",
        "eventName": "join_restaurant",
        "payload": {
          "restaurant_id": "a1b2c3d4-e5f6-4789-0123-456789abcdef"
        }
      },
      "serverResponse": {
        "status": "joined",
        "room": "restaurant:a1b2c3d4-e5f6-4789-0123-456789abcdef",
        "timestamp": "2026-06-18T10:30:00Z"
      }
    }
  ],
